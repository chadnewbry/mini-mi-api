MINIME_PORT=8088
MINIME_DEVICE_TOKENS=dev-minime-token
MINIME_DATA_ROOT=.data
MINIME_GENERATOR_MODE=script
MINIME_WORKER_COUNT=1
MINIME_RUN_WORKERS=true
MINIME_WORKER_POLL_INTERVAL_MS=250
